{
  "name": "statterrain",
  "version": "0.1.0",
  "private": true,
  "description": "StatTerrain — Emergency-care resources and population-health intelligence (frontend prototype).",
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "data:validate-sources": "node scripts/public-data/validate-source-registry.mjs",
    "data:refresh-report": "node scripts/public-data/generate-refresh-report.mjs",
    "data:validate-benchmark": "node scripts/public-data/validate-source-benchmark.mjs",
    "data:pull-cms-hospitals": "node scripts/public-data/build-national-cms-hospitals.mjs",
    "data:validate-cms-hospitals": "node scripts/public-data/validate-cms-hospitals.mjs --mode auto",
    "data:validate-cms-hospitals:national": "node scripts/public-data/validate-cms-hospitals.mjs --mode national --verbose",
    "data:inspect-cms-hospital-validation": "node scripts/public-data/validate-cms-hospitals.mjs --inspect",
    "data:geocode-cms-hospitals": "node scripts/public-data/geocode-cms-hospitals.mjs",
    "data:refresh-cms-hospitals": "node scripts/public-data/run-cms-hospital-refresh.mjs",
    "data:pull-cms-dialysis": "node scripts/public-data/pull-cms-dialysis-facilities.mjs",
    "data:validate-cms-dialysis": "node scripts/public-data/validate-cms-dialysis-facilities.mjs",
    "data:compare-addresses-for-geocoding": "node scripts/public-data/compare-addresses-for-geocoding.mjs",
    "data:create-geocoding-chunks": "node scripts/public-data/create-geocoding-chunks.mjs",
    "data:normalize-cms-hospitals": "node scripts/public-data/build-national-cms-hospitals.mjs --skip-pull-if-current",
    "data:dedupe-cms-hospitals": "node scripts/public-data/build-national-cms-hospitals.mjs --skip-pull-if-current",
    "data:execute-cms-hospital-geocoding": "node scripts/public-data/build-national-cms-hospitals.mjs --skip-pull-if-current",
    "data:join-cms-hospital-geography": "node scripts/public-data/build-national-cms-hospitals.mjs --skip-pull-if-current",
    "data:build-cms-hospital-partitions": "node scripts/public-data/build-national-cms-hospitals.mjs --skip-pull-if-current",
    "data:build-national-cms-hospitals": "node scripts/public-data/build-national-cms-hospitals.mjs",
    "data:build-coverage-manifest": "node scripts/public-data/build-coverage-manifest.mjs",
    "data:build-artifact-manifest": "node scripts/public-data/build-artifact-manifest.mjs",
    "data:probe-cms-hospital-api": "node scripts/public-data/build-national-cms-hospitals.mjs --probe",
    "data:probe-cms-hospital-api:json": "node scripts/public-data/build-national-cms-hospitals.mjs --probe",
    "test:cms-pagination": "node --test tests/cms-hospital-pagination.test.mjs",
    "test:cms-national-validation": "node --test tests/cms-national-validation.test.mjs",
    "data:sync-national-cms-hospital-public-assets": "node scripts/public-data/sync-national-cms-hospital-public-assets.mjs",
    "prebuild": "npm run data:sync-national-cms-hospital-public-assets",
    "test:cms-public-activation": "node --test tests/cms-public-activation.test.mjs",
    "data:audit-cms-partition-resolution": "node scripts/public-data/audit-cms-partition-resolution.mjs",
    "test:cms-partition-resolution": "node --test tests/cms-partition-resolution.test.mjs",
    "data:audit-cms-hospital-fields": "node scripts/public-data/audit-cms-hospital-fields.mjs",
    "test:cms-field-completeness": "node --test tests/cms-field-completeness.test.mjs",
    "test:facility-contact-fields": "node --test tests/facility-contact-fields.test.mjs",
    "data:audit-cms-identity-refresh": "node scripts/public-data/audit-cms-identity-refresh.mjs",
    "test:cms-cache-reuse": "node --test tests/cms-cache-reuse.test.mjs",
    "test:cms-metric-reconciliation": "node --test tests/cms-metric-reconciliation.test.mjs",
    "test:planning-location": "node --test tests/planning-location.test.mjs",
    "test:radius-control": "node --test tests/radius-control.test.mjs",
    "test:research-layer-registry": "node --test tests/research-layer-registry.test.mjs",
    "test:evidence-contract": "node --test tests/evidence-contract.test.mjs",
    "test:geocode-route": "node --test tests/geocode-route.test.mjs",
    "test:search-transaction": "node --test tests/search-transaction.test.mjs",
    "test:search-regression": "node --experimental-transform-types --test tests/search-regression.test.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
