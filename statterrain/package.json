{
  "name": "statterrain",
  "version": "0.1.0",
  "private": true,
  "description": "StatTerrain — Emergency-care resources and population-health intelligence (frontend prototype).",
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "data:validate-sources": "node scripts/public-data/validate-source-registry.mjs",
    "data:refresh-report": "node scripts/public-data/generate-refresh-report.mjs",
    "data:validate-benchmark": "node scripts/public-data/validate-source-benchmark.mjs"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
